# DESI Data Share — MCP connector settings (READ-ONLY).
# Copy this file to `.env` and fill in. NEVER put the master password here —
# this connector only reads, and the master password is what the server
# requires for any write/delete, so keeping it out makes writes impossible.

# --- Supabase project (these are PUBLIC values already shipped in the web app,
#     viewer/index.html; safe to keep here) ---
SUPABASE_URL=https://pxlrlhtcvwkqnlryencs.supabase.co
SUPABASE_ANON_KEY=sb_publishable_2K4sqMmKk3g20Jmwho-awQ_Uu_hSKeU

# --- OPTIONAL: only needed to read your PRIVATE (non-public) projects ---
# The shared admin/owner password (the one used by "サーバから一覧取得").
# Leave blank to work with PUBLIC projects only.
OWNER_ADMIN_PASSWORD=

# --- OPTIONAL: per-project password override, if a project uses its own
#     viewer/admin password. One line per project:
#     PROJECT_PW__<slug>=<password>
# Example:
# PROJECT_PW__260422_aikawa_uterus_visium=myviewerpassword

# =====================================================================
# HTTP (ChatGPT / hosted) settings — only needed for `npm run serve`.
# The local Claude MCP server (`npm start`) ignores these.
# =====================================================================

# Required for the HTTP server: the shared secret that protects the endpoint.
# Put the SAME value into your ChatGPT Custom GPT's Action auth (Bearer/API key).
# Use a long random string. On Render this is generated for you.
CONNECTOR_API_KEY=

# Read-ONLY password for the registered MRM library (gates /mrm and /exp, and
# the MCP search_mrm / build_exp tools). This is the value you pass to
# set_mrm_read_password('...') in the Supabase SQL Editor. It is SEPARATE from —
# and must DIFFER from — the master password. NEVER put the master password here;
# this connector only reads. Leave blank to keep /mrm and /exp disabled.
MRM_READ_PW=

# Port for the HTTP server (default 3000). Hosts like Render set PORT for you.
PORT=3000

# Safety valve for the PUBLIC-internet endpoint. "true" = only PUBLIC projects
# are ever exposed (recommended for the hosted version). Set "false" ONLY if you
# trust this endpoint and want it to also read private projects (then also set
# OWNER_ADMIN_PASSWORD / PROJECT_PW__<slug>). The local MCP server leaves this
# unset (private access via password stays on).
PUBLIC_ONLY=true
